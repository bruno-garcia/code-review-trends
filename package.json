{
  "name": "code-review-trends",
  "private": true,
  "workspaces": ["app", "pipeline", "infra"],
  "scripts": {
    "dev": "./dev.sh",
    "dev:app": "./dev.sh app",
    "dev:infra": "./dev.sh infra",
    "dev:down": "./dev.sh down",
    "build": "npm run build --workspace=app",
    "build:pipeline": "npm run build --workspace=pipeline",
    "lint": "npm run lint --workspace=app && npm run lint --workspace=pipeline && npm run lint --workspace=infra",
    "test": "npm run test --workspace=app",
    "test:e2e": "npm run test:e2e --workspace=app",
    "pipeline": "npm run cli --workspace=pipeline --",
    "inspect": "npm run inspect --workspace=pipeline --",
    "validate": "npm run validate --workspace=pipeline"
  }
}
