{
  "name": "code-review-trends-infra",
  "version": "0.1.0",
  "private": true,
  "description": "Infrastructure for Code Review Trends (GCP + Pulumi)",
  "main": "index.ts",
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "eslint . --ext .ts --ignore-pattern node_modules --ignore-pattern bin",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:vm": "./test-vm.sh",
    "preview": "pulumi preview",
    "up": "pulumi up",
    "destroy": "pulumi destroy"
  },
  "dependencies": {
    "@pulumi/gcp": "^8.0.0",
    "@pulumi/pulumi": "^3.0.0",
    "@pulumi/random": "^4.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
