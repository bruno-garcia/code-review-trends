{
  "name": "pipeline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "cli": "tsx src/cli.ts",
    "inspect": "tsx src/tools/inspect-data.ts",
    "validate": "tsx src/tools/validate-schema.ts",
    "discover-bots": "tsx src/tools/discover-bots.ts",
    "status": "tsx src/tools/status.ts",
    "test": "node --import tsx --test src/**/*.test.ts --test-skip-pattern='smoke|app-queries'",
    "test:smoke": "node --import tsx --test src/smoke.test.ts",
    "test:app-queries": "node --import tsx --test src/app-queries.test.ts",
    "test:integration": "node --import tsx --test src/smoke.test.ts src/app-queries.test.ts"
  },
  "dependencies": {
    "@clickhouse/client": "^1.17.0",
    "@google-cloud/bigquery": "^8.1.1",
    "@octokit/rest": "^21.1.1",
    "@sentry/node": "^10.38.0"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^22",
    "eslint": "^9",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "typescript-eslint": "^8.55.0"
  }
}
